{
  "name": "test-case-generator-ai",
  "displayName": "AI Unit Test Generator",
  "description": "Generate unit tests for selected code using AI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-test-generater",
          "title": "AI Unit Test",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "ai-test-generater": [
        {
          "type": "webview",
          "id": "ai-test-generator.preview",
          "name": "Generated Tests",
          "icon": "somthing"
        }
      ]
    },
    "commands": [
      {
        "command": "test-case-generator-ai.generateTests",
        "title": "Generate Unit Tests with AI",
        "category": "AI Tests"
      }
    ],
    "keybindings": [
      {
        "command": "test-case-generator-ai.generateTests",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "test-case-generator-ai.generateTests",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.43.0"
  }
}
